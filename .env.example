# ============================================
# SignalHunt Environment Variables
# Copy this file to .env and fill in values
# ============================================

# --- Database ---
DATABASE_URL="postgresql://signalhunt:signalhunt_dev@localhost:5432/signalhunt_dev"
POSTGRES_USER=signalhunt
POSTGRES_PASSWORD=signalhunt_dev
POSTGRES_DB=signalhunt_dev

# --- Redis ---
REDIS_URL="redis://localhost:6379"

# --- Auth ---
JWT_SECRET="CHANGE_ME_IN_PRODUCTION_use_openssl_rand_hex_64"
JWT_EXPIRES_IN="24h"

# --- Telephony Provider ---
# Options: mock | twilio | telnyx
# "mock" = simulated calls for development (no phone numbers needed)
# "twilio" = real Twilio calls (requires credentials below)
TELEPHONY_PROVIDER_NAME="mock"

# --- Twilio (used when TELEPHONY_PROVIDER_NAME=twilio) ---
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_API_KEY=""
TWILIO_API_SECRET=""
TWILIO_TWIML_APP_SID=""

# --- Webhook ---
# Set to "false" to skip signature validation (required for mock provider)
WEBHOOK_VALIDATION="false"

# --- Deepgram ---
DEEPGRAM_API_KEY=""

# --- App ---
NODE_ENV="development"
API_PORT=4000
API_URL="http://localhost:4000"
FRONTEND_URL="http://localhost:3000"

# --- Webhook Base URL (use ngrok for Twilio in development) ---
WEBHOOK_BASE_URL="http://localhost:4000"
